NEXT_PUBLIC_TEAM_CONTACT_EMAIL=team@active.vc

# Admin Authentication
ADMIN_PASSWORD=

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GitHub (for file editing and deployment via GitHub API)
# Generate token from: https://github.com/settings/tokens with `repo` scope
GITHUB_TOKEN=
GITHUB_OWNER=activecapital
GITHUB_REPO=active_vc

# Optional: Upstash Redis for distributed rate limiting (recommended for production)
# Get from: https://upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Production Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Staging Supabase project (set these in Vercel for the `staging` branch only)
# NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
#NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Staging preview URL (shown in admin UI)
NEXT_PUBLIC_STAGING_URL=https://activecapital2024-git-staging-activecapital2024.vercel.app/