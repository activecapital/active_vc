NEXT_PUBLIC_TEAM_CONTACT_EMAIL=team@active.vc

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GitHub (for file editing and deployment via GitHub API)
# Generate token from: https://github.com/settings/tokens with `repo` scope
GITHUB_TOKEN=
GITHUB_OWNER=activecapital
GITHUB_REPO=active_vc

# Optional: Upstash Redis for distributed rate limiting (recommended for production)
# Get from: https://upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Staging Supabase project (used locally and on staging branch)
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Production Supabase project (used by publish/revert and public reads in production)
NEXT_PUBLIC_PRODUCTION_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_PRODUCTION_SUPABASE_ANON_KEY=your-production-anon-key
PRODUCTION_SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Staging preview URL (shown in admin UI)
NEXT_PUBLIC_STAGING_URL=https://staging.active.vc/