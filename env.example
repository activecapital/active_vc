NEXT_PUBLIC_TEAM_CONTACT_EMAIL=team@active.vc

# Admin Authentication
ADMIN_PASSWORD=''

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# GitHub Personal Access Token (for git automation)
# Generate from: https://github.com/settings/tokens
# Needs: repo scope
GITHUB_TOKEN=

# Optional: Upstash Redis for distributed rate limiting (recommended for production)
# Get from: https://upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
